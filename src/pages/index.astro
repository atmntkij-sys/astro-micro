---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const categories = [...new Set(allPosts.map(post => post.data.category?.trim()).filter(Boolean))].sort();

const blog = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      
      <!-- [테스트] 카테고리 영역: 화면 상단에 크게 배치 -->
      <section class="animate border-b pb-8">
        <h2 class="font-bold text-black dark:text-white text-xl mb-4">
          분류별 보기 ({categories.length})
        </h2>
        <div class="flex flex-wrap gap-3">
          <a href="/blog" class="px-4 py-2 rounded-md bg-black text-white dark:bg-white dark:text-black text-sm font-medium">
            전체 ({allPosts.length})
          </a>
          {categories.map(category => (
            <a 
              href={`/category/${category}`} 
              class="px-4 py-2 rounded-md bg-gray-100 dark:bg-gray-800 hover:bg-blue-500 hover:text-white transition-all text-sm shadow-sm"
            >
              #{category} ({allPosts.filter(p => p.data.category?.trim() === category).length})
            </a>
          ))}
        </div>
      </section>

      <!-- 포스트 목록 영역 -->
      <main class="animate space-y-6">
        <div class="flex items-center justify-between">
          <h2 class="font-semibold text-black dark:text-white">
            Latest posts
          </h2>
          <a href="/blog" class="text-sm text-blue-500 hover:underline">View all &rarr;</a>
        </div>
        <ul class="not-prose flex flex-col gap-4">
          {blog.map((post) => (
            <li><ArrowCard entry={post} /></li>
          ))}
        </ul>
      </main>

    </div>
  </Container>
</Layout>