---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import CategoryMenu from "@components/CategoryMenu.astro"; // 방금 만든 컴포넌트 추가

import { SITE, HOME, SOCIALS } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";


// 블로그 포스트만 가져옵니다. 프로젝트 관련 코드는 삭제했습니다.
const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <!-- 1000px 내부를 2:8 정도로 쪼개는 그리드 레이아웃 -->
    <div class="grid grid-cols-1 md:grid-cols-[220px_1fr] gap-12">
      
      <!-- 좌측: 사이드바 메뉴 -->
      <aside class="hidden md:block">
        <div class="sticky top-24">
          <CategoryMenu />
        </div>
      </aside>

      <!-- 우측: 메인 본문 -->
      <main>
        <section class="animate space-y-6">
          <div class="flex flex-wrap items-center justify-between gap-y-2">
            <h2 class="font-semibold text-black dark:text-white">
              Latest posts
            </h2>
          </div>
          <ul class="not-prose flex flex-col gap-4">
            {blog.map((post) => (
              <li><ArrowCard entry={post} /></li>
            ))}
          </ul>
        </section>
      </main>

    </div>
  </Container>
</Layout>