---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import { getCollection } from "astro:content";

// 1. 데이터 수집 (로그 확인용 console.log 포함)
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const categories = [...new Set(allPosts.map(post => post.data.category?.trim()).filter(Boolean))].sort();

console.log("검색된 카테고리:", categories); // 빌드 로그에서 확인 가능

const blog = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <!-- 레이아웃을 Flex로 변경하여 더 안정적으로 배치 -->
    <div class="flex flex-col md:flex-row gap-10">
      
      <!-- 좌측 사이드바 (너비 고정 및 가시성 확보) -->
      <aside class="w-full md:w-[200px] shrink-0">
        <div class="sticky top-24">
          <h2 class="font-bold text-xl text-black dark:text-white mb-6 border-b-2 border-blue-500 pb-2">
            Categories
          </h2>
          
          {categories.length === 0 && <p class="text-sm opacity-50">카테고리 없음</p>}
          
          <nav>
            <ul class="space-y-4">
              <li>
                <a href="/blog" class="block py-1 hover:text-blue-500 font-medium transition-colors">
                  전체보기 ({allPosts.length})
                </a>
              </li>
              {categories.map(category => (
                <li>
                  <a 
                    href={`/category/${category}`} 
                    class="flex items-center justify-between group py-1 hover:text-blue-500 transition-colors"
                  >
                    <span class="text-sm"># {category}</span>
                    <span class="text-[10px] bg-gray-200 dark:bg-gray-800 px-2 py-0.5 rounded-full group-hover:bg-blue-500 group-hover:text-white">
                      {allPosts.filter(p => p.data.category?.trim() === category).length}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>

      <!-- 우측 메인 영역 -->
      <main class="flex-grow">
        <section class="animate space-y-6">
          <div class="flex items-center justify-between border-b pb-2 mb-6">
            <h2 class="font-semibold text-black dark:text-white text-lg">
              Latest posts
            </h2>
            <a href="/blog" class="text-xs text-blue-500 hover:underline">전체보기 &rarr;</a>
          </div>
          
          {blog.length === 0 && <p>등록된 게시글이 없습니다.</p>}
          
          <ul class="not-prose flex flex-col gap-4">
            {blog.map((post) => (
              <li><ArrowCard entry={post} /></li>
            ))}
          </ul>
        </section>
      </main>

    </div>
  </Container>
</Layout>