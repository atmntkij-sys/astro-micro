---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro"; // 기존 레이아웃 경로에 맞춰 수정하세요
import ArrowCard from "@/components/ArrowCard.astro"; // 포스트 카드 컴포넌트 (있는 경우)

// 1. 빌드 시 생성될 정적 경로 정의 (SSG)
export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => {
    return data.draft !== true; // 드래프트 제외
  });

  // 모든 카테고리 추출 (중복 제거)
  const categories = [...new Set(allPosts.map((post) => post.data.category || "미분류"))];

  // 각 카테고리별로 페이지 생성 설정
  return categories.map((category) => {
    const filteredPosts = allPosts
      .filter((post) => (post.data.category || "미분류") === category)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()); // 최신순 정렬

    return {
      params: { category }, // URL 파라미터 (예: /category/맛집)
      props: { posts: filteredPosts }, // 해당 페이지에 넘겨줄 데이터
    };
  });
}

// 2. 전달받은 props와 params 가져오기
const { category } = Astro.params;
const { posts } = Astro.props;
---

<BaseLayout title={`#${category} 관련 글`} description={`${category} 카테고리의 포스트 목록입니다.`}>
  <section class="animate space-y-6">
    <div class="flex items-center gap-2">
      <h1 class="font-semibold text-black dark:text-white text-3xl">
        Category: <span class="text-blue-500">#{category}</span>
      </h1>
      <span class="text-sm bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded-full">
        {posts.length}개의 포스트
      </span>
    </div>

    <hr class="border-gray-200 dark:border-gray-800" />

    <ul class="flex flex-col gap-4">
      {
        posts.map((post) => (
          <li>
            {/* 기존 테마의 포스트 리스트 스타일을 그대로 사용하세요 */}
            <a 
              href={`/blog/${post.id}`} 
              class="group flex flex-col p-4 rounded-lg border border-black/10 dark:border-white/10 hover:bg-black/5 dark:hover:bg-white/5 transition-colors duration-300"
            >
              <div class="flex items-center justify-between">
                <span class="font-medium text-black dark:text-white group-hover:text-blue-500">
                  {post.data.title}
                </span>
                <time class="text-sm opacity-60">
                  {post.data.date.toLocaleDateString('ko-KR')}
                </time>
              </div>
              <p class="text-sm line-clamp-2 opacity-60 mt-2">
                {post.data.description}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
    
    <div class="mt-12">
      <a href="/blog" class="text-sm hover:underline text-blue-500">
        &larr; 전체 글 목록으로 돌아가기
      </a>
    </div>
  </section>
</BaseLayout>