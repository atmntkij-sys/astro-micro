---
import { getCollection } from "astro:content";
// @/layouts 대신 상대 경로인 ../../layouts로 수정합니다.
import BaseLayout from "../../layouts/BaseLayout.astro"; 
import Container from "../../components/Container.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => {
    return data.draft !== true;
  });
  
  // 카테고리 추출 및 공백 제거
  const categories = [...new Set(allPosts.map(p => p.data.category?.trim() || "미분류"))];

  return categories.map((category) => ({
    params: { category },
    props: { 
      posts: allPosts.filter(p => (p.data.category?.trim() || "미분류") === category),
      displayName: category 
    },
  }));
}

const { displayName, posts } = Astro.props;
---

<BaseLayout title={`${displayName} | ${displayName}`}>
  <Container>
    <div class="space-y-10">
      <h1 class="animate font-semibold text-black dark:text-white">
        #{displayName} 카테고리
      </h1>
      <ul class="flex flex-col gap-4">
        {posts.map(post => (
          <li class="animate">
            <a href={`/blog/${post.id.replace(/\.[^/.]+$/, "")}`} class="font-medium hover:text-blue-500">
              {post.data.title}
            </a>
            <p class="text-sm text-gray-500">{post.data.description}</p>
          </li>
        ))}
      </ul>
    </div>
  </Container>
</BaseLayout>